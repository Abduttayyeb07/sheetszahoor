# Spreadsheet that receives Capital In / Capital Out (the 3 vault tabs).
SHEET_A_ID=

# Spreadsheet that logs raw INFLOW/OUTFLOW transactions.
SHEET_B_ID=

# How often the ongoing sync checks for new transactions, in milliseconds.
POLL_INTERVAL_MS=3600000

# Service account auth — use ONE of the two options below.

# Option 1: path to the service account JSON key file (mounted into the container).
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Option 2: the full JSON key content as a single-line string (no file needed,
# works well with secret managers / CI). Takes priority over the path above.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
