# Spreadsheet that receives Capital In / Capital Out (the 3 vault tabs).
SHEET_A_ID=

# How often the ongoing sync checks for new transactions, in milliseconds.
POLL_INTERVAL_MS=3600000

# Google service account auth — use ONE of the two options below.
GOOGLE_CREDENTIALS_PATH=./credentials.json
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# ClickHouse connection (reached through the SSH tunnel below — CH_HOST/CH_PORT
# are the DB's address as seen from the SSH server, not directly reachable).
CH_HOST=
CH_PORT=
CH_USER=
CH_PASSWORD=
CH_DATABASE=
CH_TABLE=core_transactions

# SSH tunnel used to reach ClickHouse. SSH_HOST defaults to CH_HOST if unset.
SSH_HOST=
SSH_PORT=22
SSH_USER=
# Auth: use ONE of the two options below.
SSH_KEY_PATH=/app/ssh_key
SSH_PASSPHRASE=
# SSH_PASSWORD=
